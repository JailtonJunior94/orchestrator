{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bug-schema.json",
  "title": "Bug Report Array",
  "description": "Schema canonico para arrays de bugs reportados por agentes de analise.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "severity", "file", "line", "reproduction", "expected", "actual"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "description": "Identificador unico do bug (ex: BUG-001)."
      },
      "severity": {
        "type": "string",
        "enum": ["critical", "high", "medium", "low"],
        "description": "Nivel de severidade do bug."
      },
      "file": {
        "type": "string",
        "description": "Caminho do arquivo onde o bug foi encontrado."
      },
      "line": {
        "type": "integer",
        "description": "Numero da linha onde o bug foi encontrado."
      },
      "reproduction": {
        "type": "string",
        "description": "Passos para reproduzir o bug."
      },
      "expected": {
        "type": "string",
        "description": "Comportamento esperado."
      },
      "actual": {
        "type": "string",
        "description": "Comportamento observado."
      }
    }
  }
}
